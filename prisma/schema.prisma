generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id          String    @id @default(uuid())
  title       String
  description String
  date        DateTime
  location    String
  maxSeats    Int
  imageUrl    String?  
  price       Int       @default(0) // store in smallest currency unit (for INR)

  bookings    Booking[]
}

model Booking {
  id                String        @id @default(uuid())
  eventId           String
  userId            String

  event             Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  status            BookingStatus @default(ACTIVE)
  paymentStatus     PaymentStatus @default(PENDING)
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?

  createdAt         DateTime      @default(now())
  cancelledAt       DateTime?

  @@unique([eventId, userId])
}
enum BookingStatus {
  ACTIVE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}


model User {
  id        String    @id @default(uuid())
  username  String
  email     String    @unique
  password  String
  role         Role      @default(USER)
  createdAt DateTime  @default(now())
  refreshToken String?  
  bookings  Booking[]
}

enum Role {
  USER
  ADMIN
}