generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id          String    @id @default(uuid())
  title       String
  description String
  date        DateTime
  location    String
  maxSeats    Int
  imageUrl    String?  
  bookings    Booking[]
}

model Booking {
  id        String   @id @default(uuid())
  eventId   String
  userId    String

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([eventId, userId]) // one booking per user per event
}

model User {
  id        String    @id @default(uuid())
  username  String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  refreshToken String?  
  bookings  Booking[]
}